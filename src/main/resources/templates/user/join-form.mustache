{{> layout/header}}

<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="content-card">
                <h1 class="text-center">회원가입</h1>
                <hr>
                <form action="/join" method="post" onsubmit="return valid()">
                    <div class="mb-3 mt-3">
                        <label for="username" class="form-label">아이디</label>
                        <div class="d-flex">
                            <input type="text" class="form-control me-2" id="username" placeholder="아이디를 입력하세요" name="username" required>
                            <button type="button" class="btn btn-outline-primary text-nowrap" onclick="usernameSameCheck()">중복체크</button>
                        </div>
                        <small id="usernameCheckMsg" class="form-text text-muted">아이디 중복 체크를 해주세요.</small>
                    </div>

                    <div class="mb-3">
                        <label for="password" class="form-label">비밀번호</label>
                        <input type="password" class="form-control" id="password" placeholder="비밀번호를 입력하세요" name="password" required>
                    </div>

                    <div class="mb-3">
                        <label for="email" class="form-label">이메일</label>
                        <input type="email" class="form-control" id="email" placeholder="이메일을 입력하세요" name="email" required>
                    </div>

                    <div class="d-grid gap-2 mt-4">
                        <button id="btnJoin" type="submit" class="btn btn-primary btn-lg" disabled>회원가입</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<script>
    let isSameCheck = false;

    function usernameSameCheck() {
        let username = document.querySelector("#username").value;

        if (!username) {
            alert("아이디를 입력해주세요.");
            return;
        }

        fetch(`/api/user/same-check?username=${username}`)
            .then(response => response.json())
            .then(responseBody => {
                if (responseBody.status === 200) {
                    alert(responseBody.msg);
                    isSameCheck = true;
                    document.querySelector("#btnJoin").disabled = false;
                    document.querySelector("#username").readOnly = true;
                    document.querySelector("#usernameCheckMsg").innerText = "사용 가능한 아이디입니다.";
                    document.querySelector("#usernameCheckMsg").classList.remove("text-muted");
                    document.querySelector("#usernameCheckMsg").classList.add("text-success");
                } else {
                    alert(responseBody.msg);
                    isSameCheck = false;
                    document.querySelector("#btnJoin").disabled = true;
                    document.querySelector("#usernameCheckMsg").innerText = responseBody.msg;
                    document.querySelector("#usernameCheckMsg").classList.remove("text-muted");
                    document.querySelector("#usernameCheckMsg").classList.add("text-danger");
                }
            })
            .catch(error => {
                console.error("Error:", error);
                alert("중복 체크 중 오류가 발생했습니다.");
            });
    }

    function valid() {
        if (!isSameCheck) {
            alert("아이디 중복 체크를 해주세요.");
            return false;
        }
        return true;
    }
</script>

{{> layout/footer}}
