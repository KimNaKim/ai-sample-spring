{{> layout/header}}

<div class="container my-5">
    <!-- 게시글 목록 그리드 -->
    <div class="row g-4">
        {{#model.boards}}
        <div class="col-md-4">
            <div class="card h-100 shadow-sm border-0 p-3" style="border-radius: var(--radius-md); background-color: var(--color-surface);">
                <div class="card-body d-flex flex-column">
                    <h5 class="card-title fw-bold mb-3 text-truncate" style="color: var(--color-text-main);">{{title}}</h5>
                    <p class="card-text small overflow-hidden" style="color: var(--color-text-muted); display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; height: 3rem;">
                        {{content}}
                    </p>
                    <div class="mt-4 pt-3 border-top d-flex justify-content-between align-items-center" style="border-color: var(--color-border) !important;">
                        <span class="small text-muted">No. {{id}}</span>
                        <a href="/board/{{id}}" class="btn btn-sm fw-bold px-3" 
                           style="color: var(--color-primary); background-color: #eef6ff; border: none; border-radius: var(--radius-sm);">
                            상세보기
                        </a>
                    </div>
                </div>
            </div>
        </div>
        {{/model.boards}}
    </div>

    <!-- UI 제어: 페이징 버튼 및 번호 목록 -->
    <div class="d-flex justify-content-center mt-5">
        <ul class="pagination gap-2 border-0">
            {{#model.paging}}
            <!-- 이전 버튼 -->
            <li class="page-item {{#first}}disabled opacity-50{{/first}}">
                <a class="page-link py-2 px-4 fw-bold shadow-sm" 
                   href="/board?page={{prevPage}}" 
                   style="border-radius: var(--radius-lg); border: 1px solid var(--color-border); color: var(--color-text-main); background-color: var(--color-surface);">
                    이전
                </a>
            </li>

            <!-- 페이지 번호 목록 -->
            {{#pageNumbers}}
            <li class="page-item">
                <a class="page-link py-2 px-3 fw-bold shadow-sm" href="/board?page={{number}}" 
                   style="border-radius: var(--radius-sm); border: 1px solid var(--color-border); color: var(--color-text-main); background-color: var(--color-surface); 
                          {{#current}}background-color: var(--color-primary); color: white; border: none;{{/current}}">
                    {{number}}
                </a>
            </li>
            {{/pageNumbers}}

            <!-- 다음 버튼 -->
            <li class="page-item {{#last}}disabled opacity-50{{/last}}">
                <a class="page-link py-2 px-4 fw-bold shadow-sm text-white" 
                   href="/board?page={{nextPage}}" 
                   style="border-radius: var(--radius-lg); background-color: var(--color-primary); border: none;">
                    다음
                </a>
            </li>
            {{/model.paging}}
        </ul>
    </div>
</div>

{{> layout/footer}}
