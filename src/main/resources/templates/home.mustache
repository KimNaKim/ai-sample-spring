{{> layout/header}}

<div class="container my-5">
    <!-- 게시글 목록 그리드 -->
    <div class="row g-4">
        {{#models}}
        <div class="col-md-4">
            <div class="card h-100 shadow-sm border-0 p-3" style="border-radius: var(--radius-md); background-color: var(--color-surface); transition: transform 0.2s;">
                <div class="card-body d-flex flex-column">
                    <h5 class="card-title fw-bold mb-3 text-truncate" style="color: var(--color-text-main);">{{title}}</h5>
                    <p class="card-text small overflow-hidden" style="color: var(--color-text-muted); display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; height: 3rem;">
                        {{content}}
                    </p>
                    <div class="mt-4 pt-3 border-top d-flex justify-content-between align-items-center" style="border-color: var(--color-border) !important;">
                        <div class="d-flex align-items-center">
                            <div class="rounded-circle bg-light d-flex align-items-center justify-content-center me-2" style="width: 24px; height: 24px;">
                                <i class="fa-solid fa-user" style="font-size: 0.7rem; color: var(--color-text-muted);"></i>
                            </div>
                            <span class="small text-muted">ID: {{id}}</span>
                        </div>
                        <a href="/board/{{id}}" class="btn btn-sm fw-bold px-3" 
                           style="color: var(--color-primary); background-color: #eef6ff; border: none; border-radius: var(--radius-sm);">
                            상세보기
                        </a>
                    </div>
                </div>
            </div>
        </div>
        {{/models}}
        {{^models}}
        <div class="col-12 text-center py-5">
            <p class="text-muted">작성된 게시글이 없습니다.</p>
        </div>
        {{/models}}
    </div>

    <!-- 페이징 버튼 (학습용 수동 버튼 완성) -->
    <div class="d-flex justify-content-center mt-5">
        <ul class="pagination gap-2 border-0">
            {{#paging}}
            <li class="page-item">
                <a class="page-link py-2 px-4 fw-bold shadow-sm {{#first}}disabled opacity-50{{/first}}" 
                   href="/?page={{prevPage}}" 
                   style="border-radius: var(--radius-lg); border: 1px solid var(--color-border); color: var(--color-text-main); background-color: var(--color-surface);">
                    <i class="fa-solid fa-chevron-left me-2 small"></i>이전
                </a>
            </li>
            <li class="page-item">
                <a class="page-link py-2 px-4 fw-bold shadow-sm text-white {{#last}}disabled opacity-50{{/last}}" 
                   href="/?page={{nextPage}}" 
                   style="border-radius: var(--radius-lg); background-color: var(--color-primary); border: none;">
                    다음<i class="fa-solid fa-chevron-right ms-2 small"></i>
                </a>
            </li>
            {{/paging}}
        </ul>
    </div>
</div>

{{> layout/footer}}
