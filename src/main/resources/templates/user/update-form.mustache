{{> layout/header}}

<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="content-card shadow-sm border-0 p-4" style="border-radius: var(--radius-md); background-color: var(--color-surface);">
                <h1 class="text-center mb-4" style="color: var(--color-text-main); font-weight: 800;">회원정보수정</h1>
                <hr class="mb-4" style="border-color: var(--color-border); opacity: 0.5;">
                
                <form action="/user/update" method="post">
                    {{#user}}
                    <!-- 아이디 섹션 (수정 불가) -->
                    <div class="mb-4">
                        <label for="username" class="form-label fw-bold" style="color: var(--color-text-main);">아이디</label>
                        <input type="text" class="form-control" id="username" value="{{#username}}{{username}}{{/username}}" readonly
                               style="border-radius: var(--radius-sm); border: 1px solid var(--color-border); background-color: #f8f9fa;">
                        <div class="form-text mt-1 small" style="color: var(--color-text-muted);">아이디는 수정할 수 없습니다.</div>
                    </div>

                    <!-- 비밀번호 섹션 -->
                    <div class="mb-4">
                        <label for="password" class="form-label fw-bold" style="color: var(--color-text-main);">비밀번호 수정</label>
                        <input type="password" class="form-control" id="password" placeholder="변경할 비밀번호를 입력하세요 (미입력 시 기존 유지)" name="password"
                               style="border-radius: var(--radius-sm); border: 1px solid var(--color-border);">
                    </div>

                    <!-- 이메일 섹션 -->
                    <div class="mb-4">
                        <label for="email" class="form-label fw-bold" style="color: var(--color-text-main);">이메일</label>
                        <input type="email" class="form-control" id="email" value="{{#email}}{{email}}{{/email}}" name="email" required
                               style="border-radius: var(--radius-sm); border: 1px solid var(--color-border);">
                    </div>

                    <!-- 주소 섹션 -->
                    <div class="mb-4">
                        <label class="form-label fw-bold d-block" style="color: var(--color-text-main);">주소</label>
                        <div class="input-group mb-2">
                            <input type="text" class="form-control" id="postcode" name="postcode" value="{{#postcode}}{{postcode}}{{/postcode}}" placeholder="우편번호" readonly
                                   style="border-radius: var(--radius-sm) 0 0 var(--radius-sm); border: 1px solid var(--color-border); background-color: #fcfcfc;">
                            <button type="button" class="btn btn-secondary btn-sm fw-bold" onclick="daumPostcode()"
                                    style="border-radius: 0 var(--radius-sm) var(--radius-sm) 0; background-color: var(--color-text-muted); border: none;">
                                주소 찾기
                            </button>
                        </div>
                        <input type="text" class="form-control mb-2" id="address" name="address" value="{{#address}}{{address}}{{/address}}" placeholder="기본 주소" readonly
                               style="border-radius: var(--radius-sm); border: 1px solid var(--color-border); background-color: #fcfcfc;">
                        <div class="row g-2">
                            <div class="col-md-6">
                                <input type="text" class="form-control" id="detailAddress" name="detailAddress" value="{{#detailAddress}}{{detailAddress}}{{/detailAddress}}" placeholder="상세 주소"
                                       style="border-radius: var(--radius-sm); border: 1px solid var(--color-border);">
                            </div>
                            <div class="col-md-6">
                                <input type="text" class="form-control" id="extraAddress" name="extraAddress" value="{{#extraAddress}}{{extraAddress}}{{/extraAddress}}" placeholder="참고항목" readonly
                                       style="border-radius: var(--radius-sm); border: 1px solid var(--color-border); background-color: #fcfcfc;">
                            </div>
                        </div>
                    </div>

                    <!-- 수정 버튼 -->
                    <div class="d-grid gap-2 mt-5">
                        <button type="submit" class="btn btn-primary btn-lg fw-bold py-3"
                                style="border-radius: var(--radius-md); background-color: var(--color-primary); border: none; transition: all 0.2s;">
                            정보 수정 완료
                        </button>
                    </div>
                    {{/user}}

                    <!-- 회원 탈퇴 링크 (Footer 스타일) -->
                    <div class="text-center mt-4 pt-3 border-top" style="border-color: var(--color-border) !important;">
                        <span class="small" style="color: var(--color-text-muted);">계정을 삭제하시겠습니까?</span>
                        <a href="/user/withdraw-form" class="small fw-bold ms-1" style="color: #ef4444; text-decoration: none;">회원 탈퇴</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<script src="//t1.daumcdn.net/mapjsapi/bundle/postcode/prod/postcode.v2.js"></script>
<script>
    function daumPostcode() {
        new daum.Postcode({
            oncomplete: function(data) {
                var addr = '';
                var extraAddr = '';

                if (data.userSelectedType === 'R') {
                    addr = data.roadAddress;
                } else {
                    addr = data.jibunAddress;
                }

                if(data.userSelectedType === 'R'){
                    if(data.bname !== '' && /[동|로|가]$/g.test(data.bname)){
                        extraAddr += data.bname;
                    }
                    if(data.buildingName !== '' && data.apartment === 'Y'){
                        extraAddr += (extraAddr !== '' ? ', ' + data.buildingName : data.buildingName);
                    }
                    if(extraAddr !== ''){
                        extraAddr = ' (' + extraAddr + ')';
                    }
                    document.getElementById("extraAddress").value = extraAddr;
                } else {
                    document.getElementById("extraAddress").value = '';
                }

                document.getElementById('postcode').value = data.zonecode;
                document.getElementById("address").value = addr;
                document.getElementById("detailAddress").focus();
            }
        }).open();
    }
</script>

{{> layout/footer}}
